#!/bin/bash
# Hook pre-push: ejecuta los tests de PHPUnit antes de hacer push a cualquier rama.

MOODLE_ROOT="/Users/sergiocomeron/moodles/stable_405/moodle"
PLUGIN_DIR="$MOODLE_ROOT/blocks/validador"

echo "▶ Ejecutando tests de block_validador antes del push..."

# Comprobar que el entorno PHPUnit de Moodle está inicializado
if [ ! -f "$MOODLE_ROOT/vendor/bin/phpunit" ]; then
    echo "⚠️  vendor/bin/phpunit no encontrado en $MOODLE_ROOT"
    echo "   Ejecuta: cd $MOODLE_ROOT && composer install"
    exit 1
fi

if [ ! -f "$MOODLE_ROOT/config.php" ]; then
    echo "⚠️  No se encontró config.php en $MOODLE_ROOT. Tests omitidos."
    exit 0
fi

cd "$MOODLE_ROOT" || exit 1

# Inicializar PHPUnit si aún no está listo
if [ ! -d "$MOODLE_ROOT/phpunit" ] && [ ! -f "$MOODLE_ROOT/.phpunit.result.cache" ]; then
    echo "   Inicializando PHPUnit (primera vez)..."
    php admin/tool/phpunit/cli/init.php --quiet
fi

# Ejecutar los tests del plugin
vendor/bin/phpunit --testsuite block_validador_testsuite --testdox
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo ""
    echo "❌ Tests fallidos. Push cancelado."
    echo "   Corrige los errores antes de hacer push."
    exit 1
fi

echo "✅ Todos los tests pasan. Continuando con el push."
exit 0
